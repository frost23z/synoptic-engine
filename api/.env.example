# ── Docker Compose service config (compose.yaml) ────────────────────────────
# These vars configure the Postgres container that Spring Boot starts automatically
# during `./gradlew bootRun`. Override if the defaults conflict with something else
# running locally.
POSTGRES_DB=synoptic
POSTGRES_USER=myuser
POSTGRES_PASSWORD=secret
POSTGRES_PORT=5432

# ── Optional secret overrides for local dev ──────────────────────────────────
# application-local.yaml already provides safe dev-only defaults for all of these,
# so you can leave this section commented out and things will work fine.
# Un-comment and set values here if you want custom local secrets.
#
# JWT_SECRET=<openssl rand -base64 48>                    # ≥ 32 bytes
# SYNOPTIC_ADMIN_EMAIL=admin@synoptic.dev
# SYNOPTIC_ADMIN_PASSWORD=Admin@123
# SYNOPTIC_ENCRYPTION_KEY=<openssl rand -base64 32>       # decodes to exactly 32 bytes
#
# MAIL_HOST=localhost
# MAIL_PORT=1025
# MAIL_FROM=noreply@synopticengine.local
# MAIL_SMTP_AUTH=false
# MAIL_SMTP_STARTTLS=false
